<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Item</title>
</head>
<body>
    <h1>Edit Item</h1>
    <form action="/edit/<%= item._id %>" method="POST">
        <label for="name">Name:</label>
        <input type="text" id="name" name="name" value="<%= item.name %>" required><br><br>
        
        <label for="description">Description:</label>
        <textarea id="description" name="description" required><%= item.description %></textarea><br><br>
        
        <button type="submit" style="background-color: #007bff; color: white; padding: 10px; border: none; border-radius: 5px;">Update Item</button>
    </form>
    <a href="/"><button style="background-color: #6c757d; color: white; padding: 10px; border: none; border-radius: 5px;">Cancel</button></a>
</body>
</html>